LAMMPS (2 Aug 2023)
# LAMMPS script for symmetric tilt grain boundary (STGB) energy calculation in Mg

# Base directory where all 0–29 folders are located
variable baseDir string "/home/saurav/Desktop/STGB/new/cc_3/1-210/lammps/lammps_0"

# Define constants
variable minimumenergy equal -1.549           # Mg bulk energy per atom (eV)
variable conversionFactor equal 16021.7733   # eV/Å² → mJ/m²

# Initialize min energy and index tracker
variable minEnergy equal 1e6
variable minIndex equal -1

# Create output directory
shell mkdir -p output

# Loop over 30 subdirectories
variable dirIndex loop 79
label loop_start

# Path to current data file
variable dirName string ${baseDir}/${dirIndex}/coords.fulldata
variable dirName string /home/saurav/Desktop/STGB/new/cc_3/1-210/lammps/lammps_0/${dirIndex}/coords.fulldata
variable dirName string /home/saurav/Desktop/STGB/new/cc_3/1-210/lammps/lammps_0/1/coords.fulldata
print "Trying to read file: ${dirName}"
Trying to read file: /home/saurav/Desktop/STGB/new/cc_3/1-210/lammps/lammps_0/1/coords.fulldata

# ---------------- Initialize ----------------
clear
units metal
dimension 3
boundary p p p
atom_style atomic

# Read data file
read_data ${dirName}
read_data /home/saurav/Desktop/STGB/new/cc_3/1-210/lammps/lammps_0/1/coords.fulldata
Reading data file ...
  orthogonal box = (0 0 -41.670379) to (12.930492 50.662991 41.670379)
  1 by 4 by 4 MPI processor grid
  reading atoms ...
  2312 atoms
  read_data CPU = 0.010 seconds

# Interatomic potential
pair_style	meam/c
pair_coeff * *  library.meam.txt  Mg  Mg.meam.txt Mg
mass 1 24.320


# ---------------- Computes ----------------
compute csym all centro/atom 12
compute eng all pe/atom
compute eatoms all reduce sum c_eng

# ---------------- Minimization Step 1 ----------------
reset_timestep 0
thermo 10
thermo_style custom step pe lx ly lz press pxx pyy pzz c_eatoms

dump 1 all custom 25 dump.${dirIndex}_min1.lammpstrj mass type xs ys zs c_csym c_eng fx fy fz
dump 1 all custom 25 dump.1_min1.lammpstrj mass type xs ys zs c_csym c_eng fx fy fz
dump_modify 1 element Mg

min_style cg
minimize 1e-25 1e-25 10000 10000
