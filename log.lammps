# ---------------- GB Energy Calculation ----------------
variable esum equal "v_minimumenergy * count(all)"
variable xseng equal "c_eatoms - v_esum"
variable gbarea equal "lx * ly * 2"
variable gbe equal "v_xseng / v_gbarea"
variable gbemJm2 equal "v_gbe * v_conversionFactor"
variable gbernd equal round(v_gbemJm2)

# ---------------- Compare and Save Result ----------------
print "Directory ${dirIndex}: GB energy = ${gbemJm2} mJ/m^2"
Directory 75: GB energy = 298.456264684488 mJ/m^2
shell echo "Directory ${dirIndex}: ${gbemJm2} mJ/m^2" >> output/GB_energy_results.txt

# Check for minimum GB energy
if "${gbemJm2} < ${minEnergy}" then "jump SELF update_min"

jump SELF continue_loop
next dirIndex
jump SELF loop_start

# Path to current data file
variable dirName string ${baseDir}/${dirIndex}/coords.fulldata
variable dirName string /home/saurav/Desktop/STGB/new/cc_3/1-210/lammps/lammps_0/${dirIndex}/coords.fulldata
variable dirName string /home/saurav/Desktop/STGB/new/cc_3/1-210/lammps/lammps_0/76/coords.fulldata
print "Trying to read file: ${dirName}"
Trying to read file: /home/saurav/Desktop/STGB/new/cc_3/1-210/lammps/lammps_0/76/coords.fulldata

# ---------------- Initialize ----------------
clear
units metal
dimension 3
boundary p p p
atom_style atomic

# Read data file
read_data ${dirName}
read_data /home/saurav/Desktop/STGB/new/cc_3/1-210/lammps/lammps_0/76/coords.fulldata
Reading data file ...
  orthogonal box = (0 0 -41.670379) to (12.930492 50.662991 41.670379)
  1 by 4 by 4 MPI processor grid
  reading atoms ...
  2312 atoms
  read_data CPU = 0.007 seconds

# Interatomic potential
pair_style	meam/c
pair_coeff * *  library.meam.txt  Mg  Mg.meam.txt Mg
mass 1 24.320


# ---------------- Computes ----------------
compute csym all centro/atom 12
compute eng all pe/atom
compute eatoms all reduce sum c_eng

# ---------------- Minimization Step 1 ----------------
reset_timestep 0
thermo 10
thermo_style custom step pe lx ly lz press pxx pyy pzz c_eatoms

dump 1 all custom 25 dump.${dirIndex}_min1.lammpstrj mass type xs ys zs c_csym c_eng fx fy fz
dump 1 all custom 25 dump.76_min1.lammpstrj mass type xs ys zs c_csym c_eng fx fy fz
dump_modify 1 element Mg

min_style cg
minimize 1e-25 1e-25 10000 10000
